{
  "name": "codenanny",
  "version": "0.4.0",
  "description": "Local index of every Claude Code session: searchable timeline, paste-ready resume bundles for disconnects, and a disk reconciler that answers \"which session built this folder?\". MIT, runs locally, no cloud.",
  "license": "MIT",
  "author": "nobleglitch",
  "type": "module",
  "main": "./src/cli.js",
  "bin": {
    "codenanny": "./bin/codenanny.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "ai-coding",
    "ai-assistant",
    "session-recovery",
    "resume",
    "transcript",
    "sqlite",
    "fts5",
    "developer-tools",
    "cli"
  ],
  "homepage": "https://github.com/nobleglitch/codenanny#readme",
  "bugs": "https://github.com/nobleglitch/codenanny/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nobleglitch/codenanny.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@codenanny/core": "^0.4.0",
    "@codenanny/ui": "^0.4.0",
    "@codenanny/wizard": "^0.4.0",
    "@codenanny/adapters": "^0.4.0",
    "@codenanny/plugkit": "^0.4.0",
    "express": "^5.2.1",
    "better-sqlite3": "^12.11.1"
  }
}
